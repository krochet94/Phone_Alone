{
  "name": "phone_alone",
  "version": "1.0.0",
  "description": "full ecommerce site using mern",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "cross-env NODE_ENV=development nodemon backend/server.js",
    "dev:atlas": "cross-env NODE_ENV=development USE_ATLAS=true nodemon backend/server.js",
    "prod": "cross-env NODE_ENV=production node backend/server.js",
    "seeder": "cross-env NODE_ENV=development node backend/utils/seeder.js",
    "seeder:atlas": "cross-env NODE_ENV=development USE_ATLAS=true node backend/utils/seeder.js",
    "check:backend": "node -e \"require('./backend/app'); console.log('backend app loaded')\"",
    "install:frontend": "npm --prefix frontend install --legacy-peer-deps",
    "build:frontend": "npm --prefix frontend run build",
    "test:frontend:ci": "npm --prefix frontend test -- --watchAll=false --passWithNoTests",
    "ci:check": "npm run check:backend && npm run build:frontend"
  },
  "author": "krochet",
  "license": "ISC",
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.8.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-fileupload": "^1.4.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.1",
    "nodemailer": "^6.10.1",
    "stripe": "^20.4.1",
    "validator": "^13.7.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.10"
  },
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  }
}
